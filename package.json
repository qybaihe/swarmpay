{
  "name": "swarmpay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SwarmPay — Injective 上的自进蜂群 × 链上分润 Agent 经济体。",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vue-tsc -p web/tsconfig.json --noEmit && vite build --config web/vite.config.ts",
    "start": "tsx src/server.ts",
    "demo": "tsx scripts/demo-compare.ts",
    "bench:normalize": "PYTHONPATH=/tmp/evoship-pydeps python3 benchmarks/scripts/bench-normalize.py",
    "bench:eval": "tsx benchmarks/scripts/bench-eval.ts",
    "bench:aime": "tsx benchmarks/scripts/aime-eval.ts",
    "bench:math": "tsx benchmarks/scripts/math-eval.ts",
    "bench:icons": "python3 scripts/fetch-model-icons.py",
    "harness:ui": "npx --yes --package playwright node scripts/playground-ui-harness.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@injectivelabs/networks": "^1.20.18",
    "@injectivelabs/sdk-ts": "^1.20.18",
    "@injectivelabs/ts-types": "^1.20.18",
    "@injectivelabs/utils": "^1.20.18",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "dompurify": "^3.4.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "marked": "^18.0.5",
    "openai": "^4.67.0",
    "pinia": "^3.0.4",
    "tsx": "^4.19.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
