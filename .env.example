# ─────────────────────────────────────────────────────────────
# SwarmEndpoint 配置
# 复制为 .env 并填写。所有模型字段支持任意 OpenAI 兼容端点。
# ─────────────────────────────────────────────────────────────

# 服务端口
PORT=4000

# ── 模型后端(任意 OpenAI 兼容:中转 / Ollama / vLLM / LM Studio / OpenAI 官方) ──
# 留空 → 启用 mock 后端(无需真实模型即可本地跑通流程,方便先测骨架)
OPENAI_BASE_URL=
OPENAI_API_KEY=

# 蜂群用的"弱"模型(多只蜂并行调它)
SWARM_MODEL=qwen2.5:7b
# 聚合用的模型(可以是同一个弱模型)
AGGREGATOR_MODEL=qwen2.5:7b
# 要超越的强模型基线(仅 demo 对比用,不参与蜂群)
BASELINE_MODEL=gpt-4o

# 蜂群规模:发散层并行几只蜂
SWARM_SIZE=4
# 请求超时(ms)
REQUEST_TIMEOUT_MS=60000
# 蜂群模型单次请求超时(ms)
BEE_TIMEOUT_MS=30000

# ── EvoMap 开发套件(官方 OAuth 路径,recipe/gene/reuse 读写)──
# 方式1(推荐):注册 test_mode app,启动后访问 /oauth/start 授权拿 token
#   去 evomap.ai/dev/portal 注册,回调填 http://localhost:4000/oauth/callback
#   勾 test_mode 拿 evm_client_test_...,scope 勾 recipe:read gene:read reuse:query recipe:write
EVOMAP_CLIENT_ID=
EVOMAP_CLIENT_SECRET=
EVOMAP_REDIRECT_URI=http://localhost:4000/oauth/callback
# 方式2:直接填 access token(从 quickstart 或 /oauth/callback 复制)
EVOMAP_TOKEN=
EVOMAP_BASE_URL=https://evomap.ai
# 回流:是否把成功路径沉淀为 recipe(test mode 零风险)
EVOMAP_PUBLISH_BACKFLOW=true
